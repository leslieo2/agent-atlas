{
  "$defs": {
    "ObservabilityConfig": {
      "properties": {
        "backend": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Backend"
        },
        "export": {
          "anyOf": [
            {
              "$ref": "#/$defs/ObservabilityExportConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "project_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Project Name"
        }
      },
      "title": "ObservabilityConfig",
      "type": "object"
    },
    "ObservabilityExportConfig": {
      "properties": {
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Headers",
          "type": "object"
        },
        "protocol": {
          "default": "otlp_http",
          "title": "Protocol",
          "type": "string"
        }
      },
      "title": "ObservabilityExportConfig",
      "type": "object"
    },
    "RunnerBootstrapPaths": {
      "properties": {
        "artifact_dir": {
          "default": "/workspace/output/artifacts",
          "title": "Artifact Dir",
          "type": "string"
        },
        "artifact_manifest_path": {
          "default": "/workspace/output/artifact_manifest.json",
          "title": "Artifact Manifest Path",
          "type": "string"
        },
        "events_path": {
          "default": "/workspace/output/events.ndjson",
          "title": "Events Path",
          "type": "string"
        },
        "run_spec_path": {
          "default": "/workspace/input/run_spec.json",
          "title": "Run Spec Path",
          "type": "string"
        },
        "terminal_result_path": {
          "default": "/workspace/output/terminal_result.json",
          "title": "Terminal Result Path",
          "type": "string"
        }
      },
      "title": "RunnerBootstrapPaths",
      "type": "object"
    }
  },
  "$id": "https://agent-atlas.dev/schemas/jsonschema/run-spec.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "agent_id": {
      "default": "",
      "title": "Agent Id",
      "type": "string"
    },
    "agent_type": {
      "title": "Agent Type",
      "type": "string"
    },
    "approval_policy": {
      "anyOf": [
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approval Policy"
    },
    "artifact_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Ref"
    },
    "attempt": {
      "default": 1,
      "title": "Attempt",
      "type": "integer"
    },
    "attempt_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attempt Id"
    },
    "bootstrap": {
      "$ref": "#/$defs/RunnerBootstrapPaths"
    },
    "dataset": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset"
    },
    "dataset_sample_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset Sample Id"
    },
    "dataset_version_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset Version Id"
    },
    "entrypoint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Entrypoint"
    },
    "evaluator_config": {
      "title": "Evaluator Config",
      "type": "object"
    },
    "executor_config": {
      "title": "Executor Config",
      "type": "object"
    },
    "experiment_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Experiment Id"
    },
    "framework": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Framework"
    },
    "framework_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Framework Type"
    },
    "framework_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Framework Version"
    },
    "image_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Image Ref"
    },
    "input_summary": {
      "title": "Input Summary",
      "type": "string"
    },
    "model": {
      "title": "Model",
      "type": "string"
    },
    "model_settings": {
      "anyOf": [
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Settings"
    },
    "observability": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObservabilityConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "project": {
      "title": "Project",
      "type": "string"
    },
    "project_metadata": {
      "title": "Project Metadata",
      "type": "object"
    },
    "prompt": {
      "title": "Prompt",
      "type": "string"
    },
    "prompt_config": {
      "anyOf": [
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Config"
    },
    "published_agent_snapshot": {
      "title": "Published Agent Snapshot",
      "type": "object"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "run-spec.v1",
      "default": "run-spec.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "toolset_config": {
      "title": "Toolset Config",
      "type": "object"
    },
    "trace_backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Backend"
    }
  },
  "required": [
    "run_id",
    "project",
    "model",
    "agent_type",
    "input_summary",
    "prompt",
    "published_agent_snapshot"
  ],
  "title": "RunSpec",
  "type": "object"
}
