{
  "$defs": {
    "RunnerBootstrapPaths": {
      "properties": {
        "run_spec_path": {
          "default": "/workspace/input/run_spec.json",
          "title": "Run Spec Path",
          "type": "string"
        },
        "events_path": {
          "default": "/workspace/output/events.ndjson",
          "title": "Events Path",
          "type": "string"
        },
        "runtime_result_path": {
          "default": "/workspace/output/runtime_result.json",
          "title": "Runtime Result Path",
          "type": "string"
        },
        "terminal_result_path": {
          "default": "/workspace/output/terminal_result.json",
          "title": "Terminal Result Path",
          "type": "string"
        },
        "artifact_manifest_path": {
          "default": "/workspace/output/artifact_manifest.json",
          "title": "Artifact Manifest Path",
          "type": "string"
        },
        "artifact_dir": {
          "default": "/workspace/output/artifacts",
          "title": "Artifact Dir",
          "type": "string"
        }
      },
      "title": "RunnerBootstrapPaths",
      "type": "object"
    },
    "TracingConfig": {
      "properties": {
        "backend": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Backend"
        },
        "project_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Project Name"
        },
        "export": {
          "anyOf": [
            {
              "$ref": "#/$defs/TracingExportConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "TracingConfig",
      "type": "object"
    },
    "TracingExportConfig": {
      "properties": {
        "protocol": {
          "default": "otlp_http",
          "title": "Protocol",
          "type": "string"
        },
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Headers",
          "type": "object"
        }
      },
      "title": "TracingExportConfig",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "const": "runner-run-spec.v1",
      "default": "runner-run-spec.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "runner_backend": {
      "title": "Runner Backend",
      "type": "string"
    },
    "experiment_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Experiment Id"
    },
    "dataset_version_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset Version Id"
    },
    "dataset_sample_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset Sample Id"
    },
    "attempt": {
      "default": 1,
      "title": "Attempt",
      "type": "integer"
    },
    "attempt_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attempt Id"
    },
    "project": {
      "title": "Project",
      "type": "string"
    },
    "dataset": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Dataset"
    },
    "agent_id": {
      "default": "",
      "title": "Agent Id",
      "type": "string"
    },
    "model": {
      "title": "Model",
      "type": "string"
    },
    "entrypoint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Entrypoint"
    },
    "agent_type": {
      "title": "Agent Type",
      "type": "string"
    },
    "prompt": {
      "title": "Prompt",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "project_metadata": {
      "title": "Project Metadata",
      "type": "object"
    },
    "executor_config": {
      "title": "Executor Config",
      "type": "object"
    },
    "framework": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Framework"
    },
    "artifact_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Ref"
    },
    "image_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Image Ref"
    },
    "trace_backend": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Backend"
    },
    "tracing": {
      "anyOf": [
        {
          "$ref": "#/$defs/TracingConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "published_agent_snapshot": {
      "title": "Published Agent Snapshot",
      "type": "object"
    },
    "bootstrap": {
      "$ref": "#/$defs/RunnerBootstrapPaths"
    }
  },
  "required": [
    "run_id",
    "runner_backend",
    "project",
    "model",
    "agent_type",
    "prompt",
    "published_agent_snapshot"
  ],
  "title": "RunnerRunSpec",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-atlas.dev/schemas/jsonschema/runner-run-spec.v1.schema.json"
}
