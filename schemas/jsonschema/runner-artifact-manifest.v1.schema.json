{
  "$defs": {
    "ArtifactEntry": {
      "properties": {
        "kind": {
          "default": "file",
          "title": "Kind",
          "type": "string"
        },
        "media_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Type"
        },
        "metadata": {
          "title": "Metadata",
          "type": "object"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sha256"
        },
        "size_bytes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Bytes"
        },
        "uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        }
      },
      "required": [
        "path"
      ],
      "title": "ArtifactEntry",
      "type": "object"
    },
    "ProducerInfo": {
      "properties": {
        "framework": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Framework"
        },
        "kind": {
          "default": "runner",
          "title": "Kind",
          "type": "string"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Language"
        },
        "runtime": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runtime"
        },
        "version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Version"
        }
      },
      "title": "ProducerInfo",
      "type": "object"
    }
  },
  "$id": "https://agent-atlas.dev/schemas/jsonschema/runner-artifact-manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactEntry"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "attempt": {
      "default": 1,
      "title": "Attempt",
      "type": "integer"
    },
    "attempt_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attempt Id"
    },
    "experiment_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Experiment Id"
    },
    "producer": {
      "$ref": "#/$defs/ProducerInfo"
    },
    "run_id": {
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "runner-artifact-manifest.v1",
      "default": "runner-artifact-manifest.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "run_id"
  ],
  "title": "ArtifactManifest",
  "type": "object"
}
