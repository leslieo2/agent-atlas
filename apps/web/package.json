{
  "name": "@agent-atlas/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "sh scripts/run-local-e2e.sh",
    "test:e2e:live": "sh scripts/run-live-e2e.sh",
    "test:e2e:ui": "sh scripts/run-local-e2e.sh --ui",
    "test:watch": "vitest",
    "test:tdd": "vitest --watch",
    "test:tdd:unit": "vitest test/unit --watch",
    "test:tdd:integration": "vitest test/integration --watch",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:e2e && npm run build",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage",
    "verify:full": "npm run ci",
    "check": "npm run format:check && npm run lint && npm run typecheck",
    "lint-staged": "npx lint-staged"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-table": "^8.21.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.474.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.25",
    "eslint-config-prettier": "^10.1.5",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.12",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.7",
    "vitest": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
