# FastAPI route prefix.
AGENT_ATLAS_API_PREFIX=/api/v1

# Application name shown in docs/metadata.
AGENT_ATLAS_APP_NAME=Agent Atlas API

# Allowed browser origins for local frontend access.
AGENT_ATLAS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Model execution behavior:
# - auto: use live when an OpenAI key is configured, otherwise mock
# - live: require a real OpenAI key and execute against the real provider
# - mock: never call the real provider
AGENT_ATLAS_RUNTIME_MODE=auto

# Control-plane management store. For local development, SQLite is fine.
AGENT_ATLAS_CONTROL_PLANE_DATABASE_URL=sqlite:///./.agent-atlas-control.db

# Data-plane canonical trajectory/eval store. Use a separate database in production.
AGENT_ATLAS_DATA_PLANE_DATABASE_URL=sqlite:///./.agent-atlas-data.db

# PostgreSQL schema names used when the per-plane URLs point at the same Postgres database.
AGENT_ATLAS_CONTROL_PLANE_DATABASE_SCHEMA=control_plane
AGENT_ATLAS_DATA_PLANE_DATABASE_SCHEMA=data_plane

# Demo bootstrap data on startup:
# - true: seed demo runs/datasets when the database is empty
# - false: start with a clean state
# In live mode the application defaults to false unless you explicitly enable it.
AGENT_ATLAS_SEED_DEMO=false

# Optional worker name override. Useful when multiple workers share one database.
# AGENT_ATLAS_WORKER_NAME=atlas-worker-01

# Sleep interval between worker queue polls.
AGENT_ATLAS_WORKER_POLL_INTERVAL_SECONDS=1.0

# Lease duration before another worker may reclaim an in-flight task.
AGENT_ATLAS_WORKER_TASK_LEASE_SECONDS=30

# Read-side trace backend:
# - state: read canonical traces from Atlas-owned persistence
# - phoenix: query Phoenix for raw trace inspection
AGENT_ATLAS_TRACE_BACKEND=state

# Neutral OTLP endpoint for trace export.
AGENT_ATLAS_TRACING_OTLP_ENDPOINT=http://127.0.0.1:6006/v1/traces

# Logical tracing project name used for Agent Atlas traces.
AGENT_ATLAS_TRACING_PROJECT_NAME=agent-atlas

# Optional OTLP export headers encoded as JSON.
# AGENT_ATLAS_TRACING_HEADERS={"api_key":"..."}

# Optional Phoenix app URL for backend-owned deep links and raw span queries.
# Required only when AGENT_ATLAS_TRACE_BACKEND=phoenix.
AGENT_ATLAS_PHOENIX_BASE_URL=http://127.0.0.1:6006

# Phoenix query limit used when reconstructing run traces through the backend.
AGENT_ATLAS_PHOENIX_QUERY_LIMIT=500

# Optional Phoenix API key for raw span queries.
# AGENT_ATLAS_PHOENIX_API_KEY=...

# Preferred project-scoped key name for this app.
# Use this if you want the key to be clearly isolated from other OpenAI tools on your machine.
# AGENT_ATLAS_OPENAI_API_KEY=sk-...

# Standard OpenAI ecosystem key name. Also supported for convenience and tool compatibility.
# If both are set, the app prefers AGENT_ATLAS_OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
