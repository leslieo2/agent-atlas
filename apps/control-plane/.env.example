# FastAPI route prefix.
AGENT_ATLAS_API_PREFIX=/api/v1

# Application name shown in docs/metadata.
AGENT_ATLAS_APP_NAME=Agent Atlas API

# Allowed browser origins for local frontend access.
AGENT_ATLAS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Control-plane management store. For local development, SQLite is fine.
AGENT_ATLAS_CONTROL_PLANE_DATABASE_URL=sqlite:///./.agent-atlas-control.db

# Data-plane canonical trajectory/eval store. Use a separate database in production.
AGENT_ATLAS_DATA_PLANE_DATABASE_URL=sqlite:///./.agent-atlas-data.db

# PostgreSQL schema names used when the per-plane URLs point at the same Postgres database.
AGENT_ATLAS_CONTROL_PLANE_DATABASE_SCHEMA=control_plane
AGENT_ATLAS_DATA_PLANE_DATABASE_SCHEMA=data_plane

# Background execution job backend. `arq` is the product path; `inline` is test-only.
AGENT_ATLAS_EXECUTION_JOB_BACKEND=arq

# Redis DSN and queue name used by the Arq execution worker.
AGENT_ATLAS_EXECUTION_JOB_QUEUE_URL=redis://127.0.0.1:6379/0
AGENT_ATLAS_EXECUTION_JOB_QUEUE_NAME=agent-atlas:execution-jobs

# Neutral OTLP endpoint for trace export.
AGENT_ATLAS_TRACING_OTLP_ENDPOINT=http://127.0.0.1:6006/v1/traces

# Logical tracing project name used for Agent Atlas traces.
AGENT_ATLAS_TRACING_PROJECT_NAME=agent-atlas

# Optional OTLP export headers encoded as JSON.
# AGENT_ATLAS_TRACING_HEADERS={"api_key":"..."}

# Optional Phoenix app URL for backend-owned deep links.
AGENT_ATLAS_PHOENIX_BASE_URL=http://127.0.0.1:6006

# Optional Phoenix API key for OTLP export and deep link resolution.
# AGENT_ATLAS_PHOENIX_API_KEY=...

# Preferred project-scoped key name for this app.
# Use this if you want the key to be clearly isolated from other OpenAI tools on your machine.
# AGENT_ATLAS_OPENAI_API_KEY=sk-...
