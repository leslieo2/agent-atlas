# FastAPI route prefix.
AGENT_ATLAS_API_PREFIX=/api/v1

# Application name shown in docs/metadata.
AGENT_ATLAS_APP_NAME=Agent Atlas API

# Allowed browser origins for local frontend access.
AGENT_ATLAS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Model execution behavior:
# - auto: use live when an OpenAI key is configured, otherwise mock
# - live: require a real OpenAI key and execute against the real provider
# - mock: never call the real provider
AGENT_ATLAS_RUNTIME_MODE=auto

# SQLite database file for local state. Use an absolute path if you want to share it across terminals.
AGENT_ATLAS_DATABASE_URL=sqlite:///./.agent-atlas-local.db

# Demo bootstrap data on startup:
# - true: seed demo runs/datasets when the database is empty
# - false: start with a clean state
# In live mode the application defaults to false unless you explicitly enable it.
AGENT_ATLAS_SEED_DEMO=false

# Optional worker name override. Useful when multiple workers share one database.
# AGENT_ATLAS_WORKER_NAME=atlas-worker-01

# Sleep interval between worker queue polls.
AGENT_ATLAS_WORKER_POLL_INTERVAL_SECONDS=1.0

# Lease duration before another worker may reclaim an in-flight task.
AGENT_ATLAS_WORKER_TASK_LEASE_SECONDS=30

# Preferred project-scoped key name for this app.
# Use this if you want the key to be clearly isolated from other OpenAI tools on your machine.
# AGENT_ATLAS_OPENAI_API_KEY=sk-...

# Standard OpenAI ecosystem key name. Also supported for convenience and tool compatibility.
# If both are set, the app prefers AGENT_ATLAS_OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
